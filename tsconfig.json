{
  "compilerOptions": {
    "target": "ES2022",              
    "module": "NodeNext",            
    "moduleResolution": "NodeNext",  
    "ignoreDeprecations": "6.0",
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}